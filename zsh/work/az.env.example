# Azure tenant and subscription for azfit / azdc.
# Copy this file to az.env and fill in the IDs.
#
# Find your values with:
#   az account tenant list   --query '[].tenantId' -o tsv
#   az account list         --query '[].{name:name,id:id}' -o table
#
# This file is ignored by git (see .gitignore) so it is safe to keep checked out.

export AZ_TENANT_ID="00000000-0000-0000-0000-000000000000"
export AZ_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
